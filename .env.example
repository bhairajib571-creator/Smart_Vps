# GEMINI_API_KEY: Required for Gemini AI auto-correction features.
# Add your key in the AI Studio Settings > Secrets panel.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Telegram API ID and Hash for authentication
API_ID=
API_HASH=
BOT_TOKEN=
SESSION_STRING=
CHAT=
ADMINS=
DATABASE_URI=
